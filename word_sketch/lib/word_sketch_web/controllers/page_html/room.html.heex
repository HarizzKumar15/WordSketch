<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WordSketch - Room</title>
  <link rel="stylesheet" href="/css/room.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="game-wrapper">
    <!-- Navbar / Header -->
    <header class="game-header">
      <div class="logo">✏️ WordSketch</div>
      <div class="round-info" id="round-display">Round 1 / 3</div>
      <div class="room-pill">Room Code: <strong id="room-code-display">...</strong></div>
    </header>

    <div class="game-container">
      
      <!-- Players Sidebar -->
      <aside class="sidebar players-sidebar">
        <div class="sidebar-header">
          <h2>Players</h2>
          <span class="player-count" id="player-count">0</span>
        </div>
        <ul id="players-list" class="players-list">
          <!-- Populated by JS -->
        </ul>
      </aside>

      <!-- Main Game Area -->
      <main class="main-content">
        
        <!-- Top status bar (Timer & Word) -->
        <div class="status-bar" style="position: relative;">
          <div id="hint-toast" class="hint-toast">Hint revealed!</div>
          <div class="timer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span id="timer-display">60</span>
          </div>
          <div class="word-display" id="word-display">
            Waiting to start...
          </div>
        </div>

        <!-- Canvas Container -->
        <div id="drawing-canvas-container" class="canvas-container">
          <!-- Overlays -->
          <div id="overlay-waiting" class="canvas-overlay">
            <h2 id="waiting-msg">Waiting for players...</h2>

            <div id="rounds-selector-container" style="display:none; flex-direction: column; gap: 8px; align-items: center; margin-bottom: 24px;">
              <label for="rounds-select" style="color:var(--text-muted, #aaa); font-size:0.9rem; text-transform:uppercase; font-weight:600; letter-spacing:1px;">Number of Rounds</label>
              <select id="rounds-select" style="padding: 10px 20px; border-radius: 8px; background: var(--bg-tertiary, #333); border: 1px solid var(--border-color, #444); color: white; font-size: 1.1rem; outline: none; cursor: pointer; font-family: inherit;">
                <option value="1">1 Round</option>
                <option value="2">2 Rounds</option>
                <option value="3" selected>3 Rounds</option>
                <option value="4">4 Rounds</option>
                <option value="5">5 Rounds</option>
                <option value="10">10 Rounds (Epic)</option>
              </select>
            </div>

            <button id="btn-start-game" class="primary-btn pulse" style="display:none;">Start Game</button>
          </div>
          
          <div id="overlay-word-select" class="canvas-overlay" style="display:none;">
            <h2>Choose a word to draw!</h2>
            <div class="word-choices" id="word-choices-container">
               <!-- Buttons injected here -->
            </div>
          </div>

          <div id="overlay-game-over" class="canvas-overlay" style="display:none;">
            <h2>Game Over!</h2>
            <div class="leaderboard" id="final-leaderboard">
               <!-- Leaderboard injected here -->
            </div>

            <button id="btn-play-again" class="primary-btn">Play Again</button>
          </div>

          <canvas id="drawing-canvas" width="800" height="480"></canvas>
        </div>

        <!-- Drawing Controls (Hidden for guessers) -->
        <div class="controls" id="drawing-controls" style="display:none;">
          <div class="tool-group">
            <input type="color" id="color-picker" value="#ffffff" />
            <div class="color-presets">
              <button class="color-btn" style="background:#ffffff;" data-color="#ffffff"></button>
              <button class="color-btn" style="background:#ff3b30;" data-color="#ff3b30"></button>
              <button class="color-btn" style="background:#4cd964;" data-color="#4cd964"></button>
              <button class="color-btn" style="background:#007aff;" data-color="#007aff"></button>
              <button class="color-btn" style="background:#ffcc00;" data-color="#ffcc00"></button>
              <button class="color-btn" style="background:#5856d6;" data-color="#5856d6"></button>
              <button class="color-btn" style="background:#ff2d55;" data-color="#ff2d55"></button>
              <button class="color-btn" style="background:#1c1c1e;" data-color="#1c1c1e"></button>
            </div>
          </div>
          <div class="tool-group">
            <label for="brush-size">Size</label>
            <input type="range" id="brush-size" min="2" max="30" value="6" />
          </div>
          <div class="tool-group">
            <button id="btn-clear-canvas" class="secondary-btn">🗑️ Clear</button>
          </div>
        </div>
      </main>

      <!-- Chat Sidebar -->
      <aside class="sidebar chat-sidebar">
        <div class="sidebar-header">
          <h2>Chat</h2>
        </div>
        <div id="chat" class="messages">
          <!-- Chat messages -->
          <div class="message system">Welcome to WordSketch!</div>
        </div>
        <div class="chat-input-wrapper">
          <input type="text" id="message-input" placeholder="Type your guess here..." autocomplete="off" />
        </div>
      </aside>
    </div>
  </div>

  <script type="module" src="/assets/js/socket.js"></script>
</body>
</html>
